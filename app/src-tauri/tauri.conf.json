{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pardus Mihmandar",
  "version": "0.1.0",
  "identifier": "tr.pardusmihmandar.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pardus Mihmandar",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility"
  }
}
